############################
# OS / Editor
############################

# macOS
.DS_Store

############################
# Tools
############################

# Vim
# swap / backup / undo
[._]*.s[a-v][a-z]
!*.svg  # comment out if you don't need vector files
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# session / history
vim/.netrwhist
vim/session/
vim/sessions/

# vim-plug installed plugins
vim/plugged/

# Yazi plugins and flavors
yazi/flavors/
yazi/plugins/

############################
# Shell / REPL history
############################

# Nushell
nushell/*
!nushell/config.nu
!nushell/env.nu

# Zsh
.zsh_history
.zsh_sessions/

############################
# Logs / temp files
############################

*.log
tmp/
.cache/

############################
# Secrets
############################

.env
.env.*
*.secret
*.key
*.token

############################
# Bootstrap artifacts
############################

# If bootstrap generates machine-specific files
scripts/*.local.sh
scripts/*.tmp.sh
